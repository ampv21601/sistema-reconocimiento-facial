# Dockerfile.frontend
FROM node:20-alpine

WORKDIR /app

# Copiar package.json primero (mejor para caché de Docker)
COPY app/frontend/package*.json ./

# Instalar dependencias
RUN npm install

# Copiar el resto del código
COPY app/frontend/ ./

# Exponer puerto
EXPOSE 5173

# Comando para desarrollo
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]